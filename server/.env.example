OPENAI_API_KEY=sk-...

# Postgres with pgvector. On Supabase: Project Settings -> Database ->
# Connection string -> "Transaction pooler" (IPv4, recommended for apps).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# optional overrides
# LEDGER_CHAT_MODEL=gpt-4o-mini
# LEDGER_EMBED_MODEL=text-embedding-3-small
